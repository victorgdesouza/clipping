# APIs de noticias
NEWSAPI_API_KEY=
NEWSDATA_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
# Descoberta ampla opcional. Sem chave, o motor atual continua funcionando.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_MAX_QUERIES=12
BRAVE_SEARCH_RESULTS_PER_QUERY=20
BRAVE_SEARCH_FRESHNESS=pm
DISCOVERY_MIN_RELEVANCE_SCORE=35
DISCOVERY_PROFILE_NEW_SOURCES=5
DISCOVERY_MIN_INTERVAL_HOURS=24
SITEMAP_MAX_CHILDREN=3
SITEMAP_MAX_ARTICLES=30
# Limites de cobertura/custo por execução
NEWS_FETCH_MAX_PAGES=5
GOOGLE_RSS_MAX_QUERIES=20

# Login Google, se for usar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Criacao automatica de admin durante migrate/post_migrate
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=troque-esta-senha

# PDF
WKHTMLTOPDF_CMD=
